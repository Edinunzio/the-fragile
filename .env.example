# The Fragile — configuration. Copy to .env and adjust:  cp .env.example .env
# Nothing here is secret for a local-only setup, but .env stays gitignored anyway.

# --- Database -------------------------------------------------------------
# Used by ingest.py (on the host) and the web dashboard (in Docker).
# Host reaches the Dockerized Postgres on localhost:5432 (published port).
# The web container reaches it as host "db" (the compose service name).
DATABASE_URL=postgresql://fragile:fragile@localhost:5432/fragile

# Credentials the Postgres container initializes itself with (docker-compose).
POSTGRES_USER=fragile
POSTGRES_PASSWORD=fragile
POSTGRES_DB=fragile

# Host ports the Docker services publish on. Change these if 5432/8000 are already
# in use by another local project, and update DATABASE_URL's port to match HOST_DB_PORT.
HOST_DB_PORT=5432
HOST_WEB_PORT=8000

# --- Ingestion ------------------------------------------------------------
# Which sensor reader to use:
#   mock    — synthetic drifting values (use until the Flipper hardware arrives)
#   flipper — read a BME280 off the Flipper Zero over USB serial
READER=mock

# Serial device for the Flipper (only used when READER=flipper).
# Find it with:  ls /dev/cu.usbmodemflip_*
FLIPPER_SERIAL_PORT=/dev/cu.usbmodemflip_Xxxx1

# Seconds between readings.
POLL_INTERVAL=60

# --- Alert thresholds -----------------------------------------------------
# Fire a macOS notification when pressure DROPS by at least this many hPa over
# the window. Stored as positive magnitudes; a drop of -1.6 hPa/3h trips 1.5.
PRESSURE_DROP_1H=0.5
PRESSURE_DROP_3H=1.5

# --- Logging --------------------------------------------------------------
# ingest.py appends here; launchd also captures stdout/stderr to this path.
INGEST_LOG=./ingest.log
